{
  "name": "trackstack",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "build:packages": "npm run build --workspace=packages/core && npm run build --workspace=packages/ui",
    "build:web": "npm run build --workspace=apps/web",
    "build:desktop": "npm run build --workspace=apps/desktop"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
